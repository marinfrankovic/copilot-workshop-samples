{
  "name": "Copilot Workshop (Infra + Data)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-bicep"
      ]
    }
  },
  "postCreateCommand": "az version && python --version",
  "remoteUser": "vscode"
}
