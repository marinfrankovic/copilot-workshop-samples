{
  "name": "GitHub Copilot for Non-Coders Workshop",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": "latest",
    "ghcr.io/devcontainers/features/node:1": "22",
    "ghcr.io/devcontainers/features/python:1": "3.12"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "github.copilot.chat.enabled": false,
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-azuretools.vscode-bicep"
      ]
    }
  },
  "postCreateCommand": "npm install --global @github/copilot && az bicep install && copilot --version && az version && python --version",
  "remoteUser": "vscode"
}
